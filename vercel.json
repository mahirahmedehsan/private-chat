{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://private-chat-servar.vercel.app/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://private-chat-servar.vercel.app/socket.io/$1" },
    { "source": "/uploads/(.*)", "destination": "https://private-chat-servar.vercel.app/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
